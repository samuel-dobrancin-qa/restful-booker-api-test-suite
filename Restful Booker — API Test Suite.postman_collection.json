    {
      "name": "03 — Bookings",
      "item": [
        {
          "name": "Create Booking — valid data",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Booking ID is returned\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.bookingid).to.be.a('number');",
                  "    pm.expect(jsonData.bookingid).to.be.above(0);",
                  "});",
                  "",
                  "pm.test(\"Firstname matches what we sent\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.booking.firstname).to.eql(\"Samuel\");",
                  "});",
                  "",
                  "pm.test(\"Lastname matches what we sent\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.booking.lastname).to.eql(\"Dobrancin\");",
                  "});",
                  "",
                  "pm.test(\"Total price is correct\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.booking.totalprice).to.eql(150);",
                  "});",
                  "",
                  "pm.test(\"Deposit paid is true\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.booking.depositpaid).to.be.true;",
                  "});",
                  "",
                  "pm.test(\"Check-in date is correct\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.booking.bookingdates.checkin).to.eql(\"2026-06-01\");",
                  "});",
                  "",
                  "pm.test(\"Response time under 3000ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});",
                  "",
                  "// This is the chaining part — saves booking ID for the next request",
                  "var jsonData = pm.response.json();",
                  "pm.environment.set(\"bookingId\", jsonData.bookingid);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"firstname\": \"Samuel\",\n    \"lastname\": \"Dobrancin\",\n    \"totalprice\": 150,\n    \"depositpaid\": true,\n    \"bookingdates\": {\n        \"checkin\": \"2026-06-01\",\n        \"checkout\": \"2026-06-07\"\n    },\n    \"additionalneeds\": \"Breakfast\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/booking",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "booking"
              ]
            }
          },
          "response": []
        },
