        {
          "name": "Update Booking — valid data",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Total price was updated\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.totalprice).to.eql(200);",
                  "});",
                  "",
                  "pm.test(\"Deposit paid was updated to false\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.depositpaid).to.be.false;",
                  "});",
                  "",
                  "pm.test(\"Check-in date was updated\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.bookingdates.checkin).to.eql(\"2026-07-01\");",
                  "});",
                  "",
                  "pm.test(\"Additional needs was updated\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.additionalneeds).to.eql(\"Lunch\");",
                  "});",
                  "",
                  "pm.test(\"Response time under 3000ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
